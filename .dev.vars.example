# 仅用于本地 wrangler dev 调试，请不要提交真实密码。

# 必须修改：本地测试时也要换成真实收件域名。
DEFAULT_DOMAIN=__MUST_CHANGE_TO_YOUR_MAIL_DOMAIN__

# 必须修改：换成真实管理员邮箱。
ADMIN_EMAIL=__MUST_CHANGE_TO_ADMIN_EMAIL__

# 必须修改：本地调试密码。
ADMIN_PASSWORD=__MUST_CHANGE_TO_ADMIN_PASSWORD__

# 必须修改：主项目兼容接口密码。
WORKER_ADMIN_PASSWORD=__MUST_CHANGE_TO_WORKER_ADMIN_PASSWORD__

# 可选：管理页标题。
UI_TITLE=Cloud Mail Bridge

# 注意：KV 不在这个文件里配置。
# 推荐直接在 Cloudflare Worker 后台绑定变量名 kv。
